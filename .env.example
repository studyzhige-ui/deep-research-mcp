# ──────────────────────────────────────────────────────────────────────
# Deep Research MCP — example environment file
#
# Copy this file to `.env` and fill in your own keys. The runtime does NOT
# auto-load .env on startup; it's only consumed by tooling (pytest, ruff,
# CI). For end users wiring the server into an MCP client, the right place
# for these values is the MCP client's `env` field — see README.md.
# ──────────────────────────────────────────────────────────────────────

# ── LLM ──
# Pick ONE provider key — LiteLLM auto-detects based on DEEP_RESEARCH_LLM_MODEL.
DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

DEEP_RESEARCH_LLM_MODEL=deepseek/deepseek-v4-flash
# DEEP_RESEARCH_LLM_BASE_URL=https://api.deepseek.com/v1   # optional override

# ── Search ──
TAVILY_API_KEY=
# EXA_API_KEY=
# SERPER_API_KEY=
# BOCHA_API_KEY=
# JINA_API_KEY=

# Set to 1 to aggregate every configured engine (default: Tavily-only).
DEEP_RESEARCH_MULTI_SOURCE=0
# Free fallback when no other engine is configured.
DEEP_RESEARCH_DUCKDUCKGO_FALLBACK=1

# ── Vertical sources (optional) ──
DEEP_RESEARCH_ACADEMIC_SEARCH=0
DEEP_RESEARCH_ARXIV_SEARCH=0
DEEP_RESEARCH_PUBMED_SEARCH=0

# ── Observability (optional) ──
# LANGSMITH_API_KEY=
# LANGCHAIN_PROJECT=DeepResearch

# ── Output ──
# DEEP_RESEARCH_REPORT_DIR=/path/to/output
